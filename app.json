{
  "expo": {
    "name": "AgroGROW",
    "slug": "agrogrow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#064E3B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.agrogrow.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show local farm weather and disease risk maps."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.agrogrow.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AgroGROW needs your location for local weather and disease alerts."
        }
      ],
      "expo-localization"
    ],
    "scheme": "agrogrow",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f7b35595-7783-4da9-b15f-e0cfcc84b4b7"
      }
    }
  }
}
